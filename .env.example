ADMIN_USERNAME=you@example.com
# Dollar signs in the bcrypt hash must be escaped with a backslash (\$)
# so Next.js's env loader doesn't try to expand them as variables.
# Generate with: npm run hash-password -- "YourNewPassword"
ADMIN_PASSWORD_HASH=replace-with-output-of-npm-run-hash-password
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-48
NEXTAUTH_URL=http://localhost:3000
