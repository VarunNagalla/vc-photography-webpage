ADMIN_USERNAME=you@example.com
# Dollar signs in the bcrypt hash must be escaped with a backslash (\$)
# so Next.js's env loader doesn't try to expand them as variables.
# Generate with: npm run hash-password -- "YourNewPassword"
ADMIN_PASSWORD_HASH=replace-with-output-of-npm-run-hash-password
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-48
NEXTAUTH_URL=http://localhost:3000

# --- Storage (required in production, e.g. on Vercel) ---
# These are auto-populated by Vercel when you connect a Blob store and an
# Upstash-for-Redis integration to the project — you will not normally
# type these in by hand there. For local development against real cloud
# storage, run `vercel env pull .env.local` after connecting both, or
# paste the values from the Vercel/Upstash dashboards yourself.

# From the Vercel Blob store ("Connect Store" -> your project):
BLOB_READ_WRITE_TOKEN=

# From the Upstash-for-Redis Marketplace integration (Vercel injects these
# under the KV_REST_API_* names; @upstash/redis's Redis.fromEnv() also
# accepts the UPSTASH_REDIS_REST_* names if you set up Upstash directly):
KV_REST_API_URL=
KV_REST_API_TOKEN=
